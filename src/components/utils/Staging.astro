---
const { title } = Astro.props;
---

<section class="min-h-[70vh] flex items-center justify-center px-6">

    <div class="bg-white dark:bg-gray-800/80 border border-gray-200 dark:border-gray-700 rounded-3xl shadow-sm dark:shadow-black/20 p-10 max-w-xl w-full text-center mt-8">

        <div class="w-20 h-20 mx-auto rounded-full bg-yellow-100 dark:bg-yellow-900/30 flex items-center justify-center mb-6">
            <i class="fa-solid fa-screwdriver-wrench text-4xl text-yellow-500"></i>
        </div>

        <h1 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white" data-i18n="staging.title">
            {title || 'Contenido en desarrollo'}
        </h1>

        <p class="mt-4 text-gray-600 dark:text-gray-400 text-lg leading-relaxed" data-i18n="staging.description">
            Esta sección todavía está en desarrollo. <br />
            Muy pronto estará disponible con nuevo contenido y proyectos.
        </p>

        <a
            href="/"
            class="inline-flex items-center gap-2 mt-8 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-full transition font-semibold"
        >
            <i class="fa-solid fa-arrow-left"></i>
            <span data-i18n="staging.back">Volver al inicio</span>
        </a>

    </div>

</section>

<script>
    const title = '{{title}}';
    if (title) {
        const el = document.querySelector('[data-i18n="staging.title"]');
        if (el) el.textContent = title;
    }
</script>
