---
import ThemeToggle from '../react/ThemeToggle.jsx';

const pathname = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200">

    <nav class="max-w-7xl 2xl:max-w-[1600px] mx-auto flex items-center justify-between px-4 sm:px-6 lg:px-10 py-5">

        <div class="flex items-center gap-4 sm:gap-6 md:gap-8">

            <div class="font-semibold text-gray-600 flex items-center gap-4 sm:gap-6 text-sm sm:text-base">

                <a
                    href="/"
                    class={`hover:text-gray-800 transition pb-1 border-b-2 ${
                        pathname === '/'
                            ? 'border-red-400 text-gray-900'
                            : 'border-transparent'
                    }`}
                >
                    Inicio
                </a>

                <a
                    href="/projects"
                    class={`hover:text-gray-800 transition pb-1 border-b-2 ${
                        pathname === '/projects'
                            ? 'border-red-400 text-gray-900'
                            : 'border-transparent'
                    }`}
                >
                    Proyectos
                </a>

                <a
                    href="/about"
                    class={`hover:text-gray-800 transition pb-1 border-b-2 ${
                        pathname === '/about'
                            ? 'border-red-400 text-gray-900'
                            : 'border-transparent'
                    }`}
                >
                    Sobre mí
                </a>

            </div>

        </div>

        <ThemeToggle client:load />

    </nav>

</header>