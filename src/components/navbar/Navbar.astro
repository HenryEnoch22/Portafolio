---
import ThemeToggle from '../react/ThemeToggle.tsx';
import LanguageToggle from '../react/LanguageToggle.tsx';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800 shadow-sm dark:shadow-gray-950/50 sticky top-0 z-40">

    <nav class="max-w-7xl 2xl:max-w-[1600px] mx-auto flex items-center justify-between px-4 sm:px-6 lg:px-10 py-4 relative">

        <div class="flex items-center gap-4 sm:gap-6 md:gap-8">

            <div class="font-semibold text-gray-500 dark:text-gray-400 flex items-center gap-4 sm:gap-6 text-sm sm:text-base">

                <a
                    href="/"
                    class={`hover:text-gray-900 dark:hover:text-white transition pb-1 border-b-2 ${
                        pathname === '/'
                            ? 'border-blue-600 text-gray-900 dark:text-white'
                            : 'border-transparent'
                    }`}
                    data-i18n="nav.home"
                >
                    Inicio
                </a>

                <a
                    href="/projects"
                    class={`hover:text-gray-900 dark:hover:text-white transition pb-1 border-b-2 ${
                        pathname === '/projects'
                            ? 'border-blue-600 text-gray-900 dark:text-white'
                            : 'border-transparent'
                    }`}
                    data-i18n="nav.projects"
                >
                    Proyectos
                </a>

                <a
                    href="/about"
                    class={`hover:text-gray-900 dark:hover:text-white transition pb-1 border-b-2 ${
                        pathname === '/about'
                            ? 'border-blue-600 text-gray-900 dark:text-white'
                            : 'border-transparent'
                    }`}
                    data-i18n="nav.about"
                >
                    Sobre mí
                </a>

            </div>

        </div>

        <div class="flex items-center gap-2">
            <div class="hidden md:flex items-center gap-2">
                <LanguageToggle client:load />
                <ThemeToggle client:load />
            </div>

            <button
                id="menu-toggle"
                class="md:hidden relative w-9 h-9 flex items-center justify-center text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition text-lg"
                aria-label="Toggle menu"
            >
                <i class="fa-solid fa-bars"></i>
            </button>
        </div>

        <div
            id="mobile-menu"
            class="hidden md:hidden absolute top-full right-0 mt-2 w-44 z-50 bg-white dark:bg-gray-900 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-800 overflow-hidden"
        >
            <div class="py-1">

                <div
                    class="language-item flex items-center justify-between px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800 transition select-none"
                >
                    <span data-i18n="nav.language">Idioma</span>
                    <LanguageToggle client:load />
                </div>

                <hr class="border-gray-100 dark:border-gray-800">

                <div
                    class="theme-item flex items-center justify-between px-4 py-2.5 text-sm text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800 transition select-none"
                >
                    <span>Tema</span>
                    <ThemeToggle client:load />
                </div>

            </div>
        </div>

    </nav>

</header>

<script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');

    const openMenu = () => {
        menu?.classList.remove('hidden');
    };

    const closeMenu = () => {
        menu?.classList.add('hidden');
    };

    toggle?.addEventListener('click', (e) => {
        e.stopPropagation();

        if (menu?.classList.contains('hidden')) {
            openMenu();
        } else {
            closeMenu();
        }
    });

    document.addEventListener('click', (e) => {
        const target = e.target as Node;

        if (
            menu &&
            toggle &&
            !menu.classList.contains('hidden') &&
            !menu.contains(target) &&
            !toggle.contains(target)
        ) {
            closeMenu();
        }
    });

    document.addEventListener('keydown', (e) => {
        if (
            e.key === 'Escape' &&
            menu &&
            !menu.classList.contains('hidden')
        ) {
            closeMenu();
        }
    });

    document.querySelector('.language-item')?.addEventListener('click', (e) => {
        const btn = (e.currentTarget as HTMLElement).querySelector('button');
        const target = e.target as Node;

        if (btn && !btn.contains(target)) {
            btn.click();
        }
    });

    document.querySelector('.theme-item')?.addEventListener('click', (e) => {
        const btn = (e.currentTarget as HTMLElement).querySelector('button');
        const target = e.target as Node;

        if (btn && !btn.contains(target)) {
            btn.click();
        }
    });
</script>